# ============================================================
# Deep Research System — Environment Variables
# PRODUCTION CONFIG - DO NOT COMMIT TO PUBLIC REPOS
# ============================================================

# --- LLM API Keys ---
OPENROUTER_API_KEY=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
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# --- OpenRouter Metadata ---
OPENROUTER_SITE_URL=https://github.com/lucadidomenicodopehubs/deep-research-spec
OPENROUTER_SITE_NAME=Deep Research System

# --- Database & Storage Credentials ---
POSTGRES_PASSWORD=drs_dev_password
MINIO_ROOT_USER=drs_admin
MINIO_ROOT_PASSWORD=drs_secret_key

# --- Integrations Config ---
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
MAX_BUDGET=50.0

# --- RLM — Recursive Language Models (arXiv:2512.24601) ---
RLM_MODE=false
RLM_ENVIRONMENT=local
RLM_SANDBOX=local
RLM_LOG_DIR=./logs/rlm
RLM_ALLOW_TIER_UPGRADE=false

# --- SHINE — real LoRA serving endpoint (optional) ---
SHINE_SERVING_URL=
SHINE_LORA_CHECKPOINT=

# --- Storage ---
DATABASE_URL=postgresql+asyncpg://drs:drs_dev_password@localhost:5432/drs
REDIS_URL=redis://localhost:6379/0
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=drs_admin
MINIO_SECRET_KEY=drs_secret_key
MINIO_BUCKET=deep-research

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# --- Observability ---
PROMETHEUS_PORT=9090
LOG_LEVEL=INFO
