{
  "dashboard": {
    "id": null,
    "uid": "drs-overview",
    "title": "DRS Overview",
    "tags": ["drs"],
    "timezone": "browser",
    "schemaVersion": 16,
    "refresh": "5s",
    "panels": [
      {
        "id": 1,
        "title": "Active Runs",
        "type": "stat",
        "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "drs_active_runs",
            "refId": "A"
          }
        ],
        "options": {
          "graphMode": "area",
          "colorMode": "value"
        }
      },
      {
        "id": 2,
        "title": "Total Cost (24h)",
        "type": "stat",
        "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "increase(drs_total_cost_dollars[24h])",
            "refId": "A"
          }
        ],
        "options": {
          "graphMode": "area",
          "colorMode": "value",
          "unit": "currencyUSD"
        }
      },
      {
        "id": 3,
        "title": "Success Rate",
        "type": "gauge",
        "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "rate(drs_runs_completed_total{status='success'}[1h]) / rate(drs_runs_started_total[1h])",
            "refId": "A"
          }
        ],
        "options": {
          "min": 0,
          "max": 1,
          "thresholds": [
            {"value": 0, "color": "red"},
            {"value": 0.8, "color": "yellow"},
            {"value": 0.95, "color": "green"}
          ]
        }
      },
      {
        "id": 4,
        "title": "Average Quality (CSS)",
        "type": "stat",
        "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "drs_avg_quality_score",
            "refId": "A"
          }
        ],
        "options": {
          "graphMode": "area",
          "colorMode": "value"
        }
      },
      {
        "id": 5,
        "title": "Runs Over Time",
        "type": "graph",
        "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(drs_runs_completed_total{status='success'}[5m])",
            "legendFormat": "Completed",
            "refId": "A"
          },
          {
            "expr": "rate(drs_runs_completed_total{status='failed'}[5m])",
            "legendFormat": "Failed",
            "refId": "B"
          }
        ],
        "xaxis": {"mode": "time"},
        "yaxis": {"label": "Runs/sec"}
      },
      {
        "id": 6,
        "title": "LLM Calls by Model",
        "type": "piechart",
        "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "sum by (model) (drs_llm_calls_total)",
            "refId": "A"
          }
        ]
      }
    ]
  }
}
