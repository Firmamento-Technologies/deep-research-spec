# ============================================================
# Deep Research System — Environment Variables Template
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# --- LLM API Keys ---
OPENROUTER_API_KEY=or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- OpenRouter Metadata ---
OPENROUTER_SITE_URL=https://github.com/lucadidomenicodopehubs/deep-research-spec
OPENROUTER_SITE_NAME=Deep Research System

# --- RLM — Recursive Language Models (arXiv:2512.24601) ---
# Master switch: false=traditional pipeline, true=RLM recursive processing
RLM_MODE=false
# REPL sandbox: local (dev) | docker (prod, required) | modal (cloud-native)
RLM_ENVIRONMENT=local
RLM_SANDBOX=local
# Sub-call log dir for RLMLogger (budget reconciliation)
RLM_LOG_DIR=./logs/rlm

# --- RLM Routing (P9 fix) ---
# Controls whether the model router is allowed to silently upgrade to a
# higher (more expensive) tier when the requested tier is unavailable.
# DANGER: setting true on a 10-section doc with 9 judges can turn a
# $0.40 economy run into a $6-8 premium run without any other warning.
# false = raise RuntimeError (fail-fast, let ops decide) [RECOMMENDED]
# true  = proceed with upgrade + COST ALERT warning in logs
RLM_ALLOW_TIER_UPGRADE=false

# --- SHINE — real LoRA serving endpoint (optional) ---
# If set: writer uses SHINE LoRA path (local vLLM/AIBrix with adapter).
# If empty: SHINE falls back to corpus mode (no false LoRA directive).
# Leave empty unless you have a dedicated GPU inference server.
SHINE_SERVING_URL=
# SHINE checkpoint path (used by ShineAdapter to load the hypernetwork)
SHINE_LORA_CHECKPOINT=

# --- Storage ---
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/deep_research
REDIS_URL=redis://localhost:6379/0
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=deep-research

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# --- Observability ---
PROMETHEUS_PORT=9090
LOG_LEVEL=INFO
