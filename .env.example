# ╔══════════════════════════════════════════════════════════════════╗
# ║          Deep Research System — Environment Configuration        ║
# ╚══════════════════════════════════════════════════════════════════╝
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ── REQUIRED ────────────────────────────────────────────────────────

# OpenRouter API key (RECOMMENDED — single key for ALL models)
# Get yours at: https://openrouter.ai/keys
# Cost: pay-per-use, no subscription
OPENROUTER_API_KEY=sk-or-v1-...

# ── OPTIONAL: Direct provider keys (only if NOT using OpenRouter) ───
# Uncomment only if you want to bypass OpenRouter for a specific provider

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...

# ── Search (optional) ────────────────────────────────────────────────
# Used by Researcher node for web search
# Get at: https://tavily.com
TAVILY_API_KEY=tvly-...

# ── Database ─────────────────────────────────────────────────────────
# PostgreSQL for checkpoints and metrics (started via docker-compose)
DATABASE_URL=postgresql://drs:drs_dev_password@localhost:5432/drs

# ── System settings ──────────────────────────────────────────────────
# Quality preset: economy | balanced | premium
QUALITY_PRESET=balanced

# SHINE token compression (requires GPU — set false if running on CPU)
SHINE_ENABLED=false

# Embedding provider: openai | local
# Use 'openai' if no GPU available (cheap, ~$0.02/1M tokens)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# Human feedback: disabled | section | document
HUMAN_FEEDBACK_MODE=disabled

# ── OpenRouter metadata (optional) ────────────────────────────────────
# Shown in OpenRouter dashboard for your app
OPENROUTER_SITE_URL=https://github.com/lucadidomenicodopehubs/deep-research-spec
OPENROUTER_SITE_NAME=Deep Research System

# ── Observability (optional) ──────────────────────────────────────────
# Prometheus metrics endpoint
METRICS_ENABLED=true
METRICS_PORT=8000

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
